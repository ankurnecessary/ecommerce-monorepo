{
  "name": "store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "next experimental-analyze",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "prettier": "prettier --write */**/*.{js,jsx,json,ts,tsx,scss,css,md}",
    "test": "run-p test:unit test:integration",
    "test:unit": "vitest --project main",
    "test:integration": "vitest --project integration-only",
    "test:coverage": "vitest run --coverage --project main",
    "lighthouse": "lhci autorun",
    "lighthouse:windows": "sh ./shell-scripts/lighthouse-windows.sh",
    "lighthouse:wsl": "bash ./shell-scripts/lighthouse-wsl.sh",
    "validate-html": "html-w3c-validator",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@repo/ui": "workspace:*",
    "lucide-react": "^1.9.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.13.0",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/nextjs-vite": "^9.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.2.3",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vitest/coverage-v8": "^3.2.3",
    "chromatic": "^13.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^9.1.3",
    "html-w3c-validator": "^1.7.0",
    "jsdom": "^26.0.0",
    "kill-port": "^2.0.1",
    "lighthouse": "^12.8.1",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.53.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^9.1.3",
    "type-fest": "^4.41.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.3",
    "vitest-matchmedia-mock": "^2.0.3",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "storybook": "$storybook"
  }
}
